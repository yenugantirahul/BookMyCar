{
  "name": "carrental",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev:backend": "turbo run dev --filter=backend",
    "dev:frontend": "turbo run dev --filter=frontend",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,yaml,yml}\"",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@types/node": "20.16.1",
    "eslint": "9.9.0",
    "eslint-config-prettier": "9.1.0",
    "prettier": "3.3.3",
    "turbo": "2.1.3",
    "typescript": "5.5.4",
    "typescript-eslint": "8.3.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.9.0"
}
